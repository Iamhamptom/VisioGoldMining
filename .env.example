# =============================================================================
# VisioGold DRC — Environment Variables
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Option A: Connection URL (Vercel Postgres, Neon, Supabase)
# When set, this takes priority over individual DB_* variables.
# DATABASE_URL=postgres://user:password@host:5432/dbname?sslmode=require

# Option B: Individual variables (local development)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=visiogold_dev
DB_ADMIN_USER=visiogold_admin
DB_ADMIN_PASSWORD=admin_password
DB_APP_USER=visiogold_app
DB_APP_PASSWORD=app_password

# Pool sizes (optional)
# DB_POOL_MAX=20
# DB_ADMIN_POOL_MAX=5

# Express server DB (uses DATABASE_URL if set, otherwise these)
# PG_HOST=localhost
# PG_PORT=5432
# PG_DATABASE=visiogold
# PG_USER=postgres
# PG_PASSWORD=postgres

# -----------------------------------------------------------------------------
# Auth
# -----------------------------------------------------------------------------
JWT_SECRET=your-jwt-secret-change-in-production-min-32-chars
JWT_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# -----------------------------------------------------------------------------
# Encryption (root key for envelope encryption — AES-256-GCM)
# Must be at least 32 characters. Required for artifact encryption.
# -----------------------------------------------------------------------------
ROOT_ENCRYPTION_KEY=your-root-encryption-key-change-in-production

# -----------------------------------------------------------------------------
# Storage
# -----------------------------------------------------------------------------
# Local filesystem path for artifact uploads (dev only)
UPLOAD_DIR=./uploads

# -----------------------------------------------------------------------------
# Express Server
# -----------------------------------------------------------------------------
# CORS_ORIGINS=http://localhost:3000
# RATE_LIMIT_MAX=100

# -----------------------------------------------------------------------------
# Supabase (required for Supabase RPC features)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# -----------------------------------------------------------------------------
# External Services
# -----------------------------------------------------------------------------
# Claude AI (Anthropic) — powers all 6 intelligence agents
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
# Redis (optional) — enables BullMQ background queue for ingestion/report jobs
# REDIS_URL=redis://localhost:6379
APP_URL=http://localhost:3000

# VisioGold org workspace (for SHARED_WITH_VISIOGOLD visibility)
# VISIOGOLD_ORG_WORKSPACE_ID=
